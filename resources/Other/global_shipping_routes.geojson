  "metadata": {
    "title": "Global Maritime Shipping Routes with Capacity/Weight Estimates",
    "description": "Illustrative GeoJSON dataset of major global shipping corridors and maritime chokepoints with estimated annual cargo volumes, oil flows, container throughput, and vessel transit counts. Designed for geospatial analysis of maritime network vulnerabilities, particularly Strait of Hormuz dependency.",
    "data_sources": [
      "IEA World Energy Outlook (oil flow estimates)",
      "EIA (Energy Information Administration) chokepoint analysis",
      "UNCTAD Review of Maritime Transport (cargo volumes, TEU estimates)",
      "World Port Index (port locations)",
      "EMODnet (shipping density patterns)",
      "Various industry reports (vessel transit estimates)"
    ],
    "caveats": [
      "All values are estimates for illustrative/analytical purposes",
      "Oil flows in million barrels per day (mb/d)",
      "Cargo in million tonnes per annum",
      "TEU in million twenty-foot equivalent units per annum",
      "Route geometries are simplified great-circle approximations",
      "Actual shipping lanes vary by vessel type, season, and conditions",
      "Data reflects approximate 2023-2024 baseline levels"
    ],
    "coordinate_reference_system": "WGS84 (EPSG:4326)",
    "created_for": "Geospatial talk: Everything Happens Somewhere",
    "total_routes": 20,
    "total_chokepoints": 7
  },
